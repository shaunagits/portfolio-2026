---
---

<section class="hero" id="home" aria-label="Introduction">
  <div class="container hero-inner">
    <div class="hero-content">
      <p class="hero-eyebrow" data-animate>
        Designer, Developer &amp; Project Lead — Available for Freelance
      </p>
      <h1 class="hero-name" data-animate data-delay="1">
        Shauna.
      </h1>
      <p class="hero-statement" data-animate data-delay="2">
        I build strategic digital experiences from concept through launch — blending design, development, and project leadership so great work actually ships.
      </p>
      <div class="hero-ctas" data-animate data-delay="3">
        <a href="#work" class="btn btn-primary">See My Work</a>
        <a href="#contact" class="btn btn-secondary">Work With Me</a>
      </div>
    </div>

    <div class="hero-logos" data-animate data-delay="4" aria-label="Past clients and employers">
      <p class="logos-label">Work informed by experience at Apple, Nike, and independent clients across web, brand, and nonprofit.</p>
    </div>
  </div>

  <div class="hero-scroll-hint" aria-hidden="true">
    <span class="scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 0 80px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 60% 40%, rgba(0,0,0,0.02) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: 1.25rem;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(4rem, 11vw, 8rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 0.92;
    color: var(--c-text);
    margin-bottom: 1.75rem;
  }

  .hero-statement {
    font-size: clamp(1.125rem, 2.2vw, 1.375rem);
    color: var(--c-text-muted);
    line-height: 1.6;
    max-width: 520px;
    margin-bottom: 2.5rem;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-ctas .btn {
    font-size: 1rem;
    padding: 1rem 2rem;
  }

  /* Logos / social proof strip */
  .hero-logos {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .logos-label {
    font-size: 0.8125rem;
    color: var(--c-text-muted);
    white-space: nowrap;
  }

  /* Scroll hint */
  .hero-scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: var(--container-px);
    display: flex;
    align-items: center;
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, var(--c-text) 0%, transparent 100%);
    animation: scrollPulse 2.2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.2; transform: scaleY(1); }
    50% { opacity: 0.6; transform: scaleY(1.15); }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 100px 0 60px;
    }
    .hero-name {
      font-size: clamp(3.5rem, 16vw, 5rem);
    }
    .hero-ctas .btn {
      width: 100%;
      justify-content: center;
    }
    .hero-logos {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .hero-scroll-hint {
      display: none;
    }
  }
</style>
