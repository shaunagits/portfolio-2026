---
interface Project {
  id: string;
  name: string;
  category: string;
  summary: string;
  image: string | null;
  thumbGradient: string;
  problem: string;
  whatIDid: string;
  outcome: string;
  tools: string[];
  link: string | null;
  featured: boolean;
}

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const panelId = `panel-${project.id}`;
const btnId = `toggle-${project.id}`;
const isFeatured = index === 0;
---

<article
  class:list={['project-card', { 'project-card--featured': isFeatured }]}
  data-category={project.category}
  data-animate
  data-delay={String(Math.min((index % 3) + 1, 5))}
>
  <div class="card-image" style={project.image ? '' : `background: ${project.thumbGradient}`}>
    {project.image && (
      <img src={project.image} alt={project.name} class="card-img" loading="lazy" />
    )}
    <span class="card-tag">{project.category}</span>
    <div class="card-overlay">
      <h3 class="card-name">{project.name}</h3>
    </div>
    <button
      class="card-trigger"
      id={btnId}
      aria-expanded="false"
      aria-controls={panelId}
    >
      <span class="sr-only">Toggle details for {project.name}</span>
    </button>
  </div>

  <div class="card-details" id={panelId} role="region" aria-labelledby={btnId}>
    <div class="card-details-inner">
      <div class="card-summary">
        <p>{project.summary}</p>
      </div>
      <div class="card-sections">
        <div class="card-section">
          <h4 class="card-detail-label">The Challenge</h4>
          <p>{project.problem}</p>
        </div>
        <div class="card-section">
          <h4 class="card-detail-label">What I Did</h4>
          <p>{project.whatIDid}</p>
        </div>
        <div class="card-section">
          <h4 class="card-detail-label">Outcome</h4>
          <p class="card-outcome">{project.outcome}</p>
        </div>
      </div>
      <div class="card-footer">
        <ul class="card-tools" aria-label="Tools used">
          {project.tools.map((tool) => (
            <li class="card-tool">{tool}</li>
          ))}
        </ul>
      </div>
      <button class="card-close" aria-label="Close details">Close</button>
    </div>
  </div>
</article>


<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .project-card {
    position: relative;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
  }

  /* ---- Image + overlay ---- */
  .card-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    transition: transform var(--transition-mid);
  }

  .project-card--featured .card-image {
    aspect-ratio: 21 / 9;
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 60%);
    opacity: 0;
    transition: opacity var(--transition-mid);
  }

  .project-card:hover .card-overlay {
    opacity: 1;
  }

  .project-card:hover .card-image {
    transform: scale(1.03);
  }

  .project-card.is-expanded .card-image {
    transform: none;
  }

  .project-card.is-expanded .card-overlay {
    opacity: 1;
  }

  .card-tag {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 3;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-sm);
  }

  .card-name {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 400;
    color: #fff;
    line-height: 1.3;
  }

  .project-card--featured .card-name {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
  }

  /* ---- Click trigger — covers image only ---- */
  .card-image {
    position: relative;
  }

  .card-trigger {
    position: absolute;
    inset: 0;
    z-index: 2;
    cursor: pointer;
  }

  /* ---- Hover lift ---- */
  .project-card {
    transition: transform var(--transition-mid);
  }

  .project-card:hover {
    transform: translateY(-4px);
  }

  .project-card.is-expanded {
    transform: none;
  }

  /* ---- Expandable details ---- */
  .card-details {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-details-inner {
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    background: var(--c-bg);
    border-top: 1px solid var(--c-border);
  }

  .card-summary p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-text-muted);
  }

  .card-sections {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .card-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-detail-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }

  .card-section p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--c-text);
    max-width: 680px;
  }

  .card-outcome {
    font-weight: 600;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--c-border);
  }

  .card-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .card-tool {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--c-text-muted);
    border: 1px solid var(--c-border);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-sm);
  }

  .card-close {
    align-self: flex-end;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    padding: 0.5rem 0;
    position: relative;
    z-index: 3;
    transition: color var(--transition-fast);
  }

  .card-close:hover {
    color: var(--c-text);
  }

  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .project-card--featured .card-image {
      aspect-ratio: 16 / 10;
    }

  }
</style>
