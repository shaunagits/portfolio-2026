---
---

<section class="contact" id="contact" aria-labelledby="contact-heading">
  <div class="container">
    <div class="contact-inner">
      <div class="contact-left">
        <p class="section-label" data-animate>Let's work together.</p>
        <h2 class="section-heading contact-heading" id="contact-heading" data-animate data-delay="1">
          Tell me what you're building.
        </h2>
        <p class="contact-sub" data-animate data-delay="2">
          I take on a limited number of projects at a time so each one gets thoughtful attention. Whether you need a website, a digital product, launch support, or a partner who can bring structure to the process — I'd love to hear about it.
        </p>
        <div class="contact-cta" data-animate data-delay="3">
          <a href="mailto:hello@shauna.digital" class="btn btn-primary contact-btn">
            hello@shauna.digital
          </a>
        </div>
      </div>

      <div class="contact-right" data-animate data-delay="2">
        <div class="contact-note">
          <p class="note-title">Currently accepting</p>
          <ul class="note-list">
            <li>
              <span class="dot available" aria-label="Available"></span>
              Freelance projects
            </li>
            <li>
              <span class="dot available" aria-label="Available"></span>
              Short-term contracts
            </li>
            <li>
              <span class="dot available" aria-label="Available"></span>
              Consulting
            </li>
            <li>
              <span class="dot available" aria-label="Available"></span>
              Project-based partnerships
            </li>
          </ul>
        </div>

        <div class="contact-links">
          <a href="https://linkedin.com/in/shauna" target="_blank" rel="noopener noreferrer" class="contact-link">
            LinkedIn
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M1 11L11 1M11 1H5M11 1v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="https://github.com/shauna" target="_blank" rel="noopener noreferrer" class="contact-link">
            GitHub
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M1 11L11 1M11 1H5M11 1v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-copy">
      &copy; {new Date().getFullYear()} Shauna. All rights reserved.
    </p>
    <p class="footer-built">
      Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>.
    </p>
  </div>
</footer>

<style>
  .contact {
    background: var(--c-text);
    color: #fff;
    --c-text-muted: rgba(255,255,255,0.55);
    --c-border: rgba(255,255,255,0.12);
    --c-surface: rgba(255,255,255,0.08);
  }

  .contact .section-label {
    color: rgba(255,255,255,0.5);
  }

  .contact .section-heading {
    color: #fff;
  }

  .contact .btn-primary {
    background: #fff;
    color: #111;
  }

  .contact .btn-primary:hover {
    background: #f0f0f0;
    box-shadow: 0 4px 24px rgba(255,255,255,0.15);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .contact-sub {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    max-width: 440px;
    margin-bottom: 2rem;
  }

  .contact-btn {
    font-size: 1rem;
    padding: 1rem 2rem;
  }

  .contact-right {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .contact-note {
    padding: 2rem;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-lg);
    background: rgba(255,255,255,0.05);
  }

  .note-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1rem;
  }

  .note-list {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .note-list li {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.8);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot.available {
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.5);
  }

  .contact-links {
    display: flex;
    gap: 1.5rem;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    transition: color var(--transition-fast);
  }

  .contact-link:hover {
    color: #fff;
  }

  /* Footer */
  .footer {
    background: #0a0a0a;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 1.5rem 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copy,
  .footer-built {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.3);
  }

  .footer-built a {
    color: rgba(255,255,255,0.5);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .footer-built a:hover {
    color: rgba(255,255,255,0.8);
  }

  @media (max-width: 800px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
