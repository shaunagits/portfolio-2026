---
---

<section class="contact" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-content">
        <p class="contact-label" data-animate>Let's work together.</p>
        <h2 class="heading-section contact-heading" data-animate data-delay="1">
          Tell me what you're building.
        </h2>
        <p class="contact-body" data-animate data-delay="2">
          I take on a limited number of projects at a time so each one gets thoughtful attention. Whether you need a website, a digital product, launch support, or a partner who can bring structure to the process, I'd love to hear about it.
        </p>
        <a href="mailto:hello@shauna.digital" class="contact-email" data-animate data-delay="3">
          hello@shauna.digital
        </a>
        <div class="contact-accepting" data-animate data-delay="3">
          <p class="contact-accepting-title">Currently accepting</p>
          <p class="contact-accepting-list">
            Freelance projects &middot; Short-term contracts &middot; Consulting &middot; Project-based partnerships
          </p>
        </div>
        <div class="contact-social" data-animate data-delay="4">
          <a href="https://www.linkedin.com/in/shaunaarnold/" target="_blank" rel="noopener noreferrer" class="contact-social-link" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/shaunagits" target="_blank" rel="noopener noreferrer" class="contact-social-link" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        </div>
      </div>

      <div class="contact-form-wrap" data-animate data-delay="2">
        <form
          class="contact-form"
          id="contact-form"
          action="https://formspree.io/f/xvzwklgz"
          method="POST"
        >
          <div class="form-field">
            <label for="contact-name" class="form-label">Name</label>
            <input type="text" id="contact-name" name="name" class="form-input" required />
          </div>
          <div class="form-field">
            <label for="contact-email" class="form-label">Email</label>
            <input type="email" id="contact-email" name="email" class="form-input" required />
          </div>
          <div class="form-field">
            <label for="contact-type" class="form-label">Project type</label>
            <select id="contact-type" name="project_type" class="form-select" required>
              <option value="" disabled selected>Select one</option>
              <option value="Web Development">Web Development</option>
              <option value="Brand & Marketing">Brand & Marketing</option>
              <option value="Digital Products">Digital Products</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="form-field">
            <label for="contact-budget" class="form-label">Budget range</label>
            <select id="contact-budget" name="budget" class="form-select" required>
              <option value="" disabled selected>Select one</option>
              <option value="Under $5k">Under $5k</option>
              <option value="$5k–$15k">$5k–$15k</option>
              <option value="$15k–$30k">$15k–$30k</option>
              <option value="$30k+">$30k+</option>
            </select>
          </div>
          <div class="form-field">
            <label for="contact-timeline" class="form-label">Timeline</label>
            <select id="contact-timeline" name="timeline" class="form-select" required>
              <option value="" disabled selected>Select one</option>
              <option value="ASAP">ASAP</option>
              <option value="1–3 months">1–3 months</option>
              <option value="3–6 months">3–6 months</option>
              <option value="Flexible">Flexible</option>
            </select>
          </div>
          <div class="form-field">
            <label for="contact-message" class="form-label">Tell me about your project</label>
            <textarea id="contact-message" name="message" class="form-textarea" rows="4" required></textarea>
          </div>
          <button type="submit" class="form-submit">Send Message</button>
        </form>
        <div class="form-success" id="form-success" hidden>
          <p class="form-success-heading">Message sent.</p>
          <p class="form-success-body">Thanks for reaching out. I'll get back to you within 1–2 business days.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-text">&copy; {new Date().getFullYear()} Shauna. All rights reserved.</p>
    <div class="footer-links">
      <a href="https://www.linkedin.com/in/shaunaarnold/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://github.com/shaunagits" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success') as HTMLElement | null;

  if (form && success) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      try {
        await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' },
        });
        form.hidden = true;
        success.hidden = false;
      } catch {
        // Fallback: submit normally
        form.submit();
      }
    });
  }
</script>

<style>
  /* ---- Contact section ---- */
  .contact {
    padding: var(--section-py) 0;
    background: var(--c-text);
    color: #fff;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ---- Left: content ---- */
  .contact-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-accent);
    margin-bottom: 1rem;
  }

  .contact-heading {
    color: #fff;
    margin-bottom: 1.5rem;
  }

  .contact-body {
    font-size: 1.125rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.6);
    max-width: 440px;
    margin-bottom: 2rem;
  }

  .contact-email {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--c-accent);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: rgba(201, 169, 110, 0.4);
    transition: text-decoration-color var(--transition-fast);
    margin-bottom: 2.5rem;
  }

  .contact-email:hover {
    text-decoration-color: var(--c-accent);
  }

  .contact-accepting {
    margin-bottom: 2rem;
  }

  .contact-accepting-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 0.5rem;
  }

  .contact-accepting-list {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
  }

  .contact-social {
    display: flex;
    gap: 1rem;
  }

  .contact-social-link {
    color: rgba(255, 255, 255, 0.4);
    transition: color var(--transition-fast);
  }

  .contact-social-link:hover {
    color: #fff;
  }

  /* ---- Right: form ---- */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition-fast);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--c-accent);
  }

  .form-select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='rgba(255,255,255,0.4)' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  .form-select option {
    background: var(--c-text);
    color: #fff;
  }

  .form-textarea {
    resize: vertical;
  }

  .form-submit {
    align-self: flex-start;
    padding: 0.875rem 2rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #fff;
    background: var(--c-accent);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background var(--transition-fast);
    margin-top: 0.5rem;
  }

  .form-submit:hover {
    background: #D4A843;
  }

  /* ---- Success state ---- */
  .form-success[hidden] {
    display: none;
  }

  .form-success {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem 0;
  }

  .form-success-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
  }

  .form-success-body {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
  }

  /* ---- Footer ---- */
  .footer {
    background: var(--c-bg-subtle);
    border-top: 1px solid var(--c-border);
    padding: 80px 0 2rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-text {
    font-size: 0.8125rem;
    color: var(--c-text-muted);
  }

  .footer-text a {
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .footer-text a:hover {
    color: var(--c-text);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.8125rem;
    color: var(--c-text-muted);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--c-text);
  }

  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.75rem;
    }
  }
</style>
